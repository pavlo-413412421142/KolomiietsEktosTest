<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="KolomiietsEktosTest.UI.Views.ItemsView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:KolomiietsEktosTest.UI.Converters">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:UnixToDateTimeConverter x:Key="UnixToDateTimeConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid Padding="10" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="60" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Toggle Unit System  -->
        <Button
            Grid.Row="0"
            Command="{Binding ToggleUnitSystemCommand}"
            IsEnabled="{Binding HasItems}"
            Text="{Binding UnitSystemButtonText}" />

        <!--  Load Items  -->
        <Button
            Grid.Row="1"
            Command="{Binding LoadItemsCommand}"
            IsEnabled="{Binding CanLoadItems}"
            Text="Get items" />

        <!--  Status area  -->
        <StackLayout
            Grid.Row="2"
            HorizontalOptions="Center"
            Orientation="Vertical"
            VerticalOptions="Center">
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            <Label
                HorizontalOptions="Center"
                IsVisible="{Binding IsEmpty}"
                Text="No items found." />
        </StackLayout>

        <!--  Items list  -->
        <CollectionView
            Grid.Row="3"
            IsVisible="{Binding HasItems}"
            ItemsSource="{Binding Items}">

            <CollectionView.Header>
                <Grid
                    Padding="10"
                    BackgroundColor="#EEE"
                    ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Label
                        Grid.Column="0"
                        FontAttributes="Bold"
                        Text="Date/Time" />
                    <Label
                        Grid.Column="1"
                        FontAttributes="Bold"
                        Text="Latitude" />
                    <Label
                        Grid.Column="2"
                        FontAttributes="Bold"
                        Text="Longitude" />
                    <Label
                        Grid.Column="3"
                        FontAttributes="Bold"
                        Text="Rod Size" />
                    <Label
                        Grid.Column="4"
                        FontAttributes="Bold"
                        Text="Pipe Size" />
                    <Label
                        Grid.Column="5"
                        FontAttributes="Bold"
                        Text="Temp" />
                </Grid>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="10" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Text="{Binding DateTimeUnix, Converter={StaticResource UnixToDateTimeConverter}}" />
                        <Label Grid.Column="1" Text="{Binding Latitude}" />
                        <Label Grid.Column="2" Text="{Binding Longitude}" />
                        <Label Grid.Column="3" Text="{Binding RodSizeDisplay}" />
                        <Label Grid.Column="4" Text="{Binding PipeSizeDisplay}" />
                        <Label Grid.Column="5" Text="{Binding TemperatureDisplay}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
